# Development-only reference configuration. Never reuse these values in production.
NEUMAN_HUB_ENVIRONMENT=development
NEUMAN_HUB_BIND=127.0.0.1:8787
NEUMAN_HUB_DATABASE=./var/neuman-hub.sqlite3
NEUMAN_HUB_OBJECT_DIR=./var/objects
NEUMAN_HUB_PUBLIC_BASE_URL=http://127.0.0.1:8787
NEUMAN_HUB_CURSOR_SECRET=replace-with-at-least-32-random-characters
NEUMAN_HUB_BOOTSTRAP_TOKEN=replace-with-a-long-random-development-token
NEUMAN_HUB_BOOTSTRAP_NAME=Local Administrator
NEUMAN_HUB_MAX_MEMBERS_PER_PROJECT=100
NEUMAN_HUB_MAX_ACTIVE_LEASES_PER_PROJECT=1000
NEUMAN_HUB_MAX_OBJECT_BYTES_PER_PROJECT=107374182400
NEUMAN_HUB_MAX_UPLOAD_BYTES=536870912
NEUMAN_HUB_EVENT_RETENTION=100000
RUST_LOG=neuman_hub=info,tower_http=info
